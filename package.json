    "framer-motion": "^12.29.0",
    "highlight.js": "^11.11.1",
    "i18next": "^25.8.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.4",
    "next-i18next": "^15.4.3",
    "nprogress": "^0.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^16.5.3",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
